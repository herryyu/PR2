% 该样式包参考了lshort-zh-cn-style.sty的编排。
\ProvidesPackage{localstyle}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% localstyle 调用的宏包
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%
% ctex 宏包 2.2(2015/06/24) 或以上版本
% ctex 宏包的字号设定会让许多固定字号的字体宏包报太多 warning，应当抑制
% 中文正文字体使用 PingFang SC
%
\RequirePackage[zihao=false, scheme=chinese]{ctex}[2015/06/24]
%
% 基本工具宏包
%
\RequirePackage{xeCJK}           % 中文字体
\RequirePackage{fontspec}        % 调用系统字体
\RequirePackage{hyperref}        % 引用、书签
\RequirePackage{geometry}        % 行间距
\RequirePackage{color}           % 设置颜色
%
% 定义
%
\def\boldred#1{{\color[rgb]{0.51,0.094,0.1}{#1}}}
\def\mkbaresec#1{\section*{\boldred{#1}}}
\def\mkpar{\par\vspace{1ex}}
%
% 行间距、页面样式
%
\linespread{1.2}
\geometry{inner=1in,outer=1.25in}
%
% 字体
%
\setmainfont{SF Pro Text}
\setCJKmainfont{PingFang SC}
%
% titlepage
%
\title{PROJECT PR2}
\author{Fijiisland}
\date{\today}